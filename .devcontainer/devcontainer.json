{
	"name": "Manim Slides",
	"image": "manimcommunity/manim:latest",
	"features": {
		"ghcr.io/devcontainers/features/git": {
			"version": "latest"
		}
	},
	"postCreateCommand": "pip install manim-slides[full]",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"rickaym.manim-sideview"
			]
		}
	},
	"remoteUser": "root"
}